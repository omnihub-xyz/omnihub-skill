# =============================================================================
# OmniHub Skill — environment template
# =============================================================================
#
# SECURITY NOTES — read before filling this in.
#
# 1. PRIVATE_KEY controls a real EOA on every supported network. Anyone who
#    obtains this value can drain the wallet and impersonate it on OmniHub
#    (since the same key is also used for OmniHub login signatures).
#
# 2. Never commit a populated .env. The repo's .gitignore excludes it, but
#    confirm with `git status` before every commit.
#
# 3. Never paste PRIVATE_KEY into chat with an AI agent, a shared terminal,
#    a screen-share, an issue tracker, or a screenshot. The skill never needs
#    you to read it back to anything; the wallet tools load it automatically.
#
# 4. Use a dedicated wallet for this agent. Do not reuse a personal or
#    treasury key. Fund only what you are willing to lose to a misconfigured
#    flow or an automated mistake.
#
# 5. AUTO_CONFIRM_TRANSACTIONS=true skips the interactive 1/2 prompt in
#    src/lib/confirm.ts. With auto-confirm on, any tool the agent runs will
#    broadcast immediately. Prefer leaving this `false` at the file level
#    and letting the skill set it inline (`AUTO_CONFIRM_TRANSACTIONS=true npm
#    run tool -- ...`) only after collecting consent in conversation.
#
# 6. If you suspect this key has been exposed: move funds out of the address
#    immediately, rotate to a new key, and replace the value below before the
#    next run.
# =============================================================================

# Wallet private key — 0x-prefixed, 64 hex chars. Required.
PRIVATE_KEY=

# Transaction confirmation policy.
#   false  — interactive 1/2 prompt before every signed transaction (recommended default)
#   true   — skip the prompt; the next signed call broadcasts immediately
AUTO_CONFIRM_TRANSACTIONS=false
